# Solana RPC — defaults to public mainnet-beta (rate limited). Helius/Triton strongly recommended.
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# Oracle + Forge AI summaries. Without this the Oracle module shows an offline state.
ANTHROPIC_API_KEY=

# Optional: GitHub token raises Forge's API rate limits (public repos work without it)
GITHUB_TOKEN=
